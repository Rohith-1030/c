#include<stdio.h>
#include <stdlib.h>

int main()
{
    int n;
    scanf("%d",&n);
    int a[n];
    for(int i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    for(int i=0;i<n;i++)
    {
        int sum=0;
        int last=a[i]%10;
        int temp=a[i];
        while(temp>=10)
        {
            temp/=10;
        }
        int first=temp;
        int l=(i==n-1)?0:i+1;
        for(int j=0;j<last;j++)
        {
            sum+=a[l];
            l++;
            if(l==n)
            {
                l=0;
            }
        }
        int m=(i==0)?n-1:i-1;
        for(int j=0;j<first;j++)
        {
            sum+=a[m];
            m--;
            if(m==-1)
            {
                m=n-1;
            }
        }
        printf("%d ",sum);
    }
    


}
