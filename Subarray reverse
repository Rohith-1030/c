#include <stdio.h>

int main()
{
    int n;
    scanf("%d", &n);
    int a[n];
    for(int i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    for(int i=0;i<n;i++)
    {
        for(int j=i;j<n;j++)
        {
            int temp[n];
            for(int k=i;k<=j;k++)
            {
                temp[k-i]=a[k];
            }
            int len=j-i+1;
            int l=0,r=len-1;
            while(l<r)
            {
                int t=temp[l];
                temp[l]=temp[r];
                temp[r]=t;
                l++;
                r--;
            }
            for(int p=0;p<len;p++)
            {
                printf("%d ",temp[p]);
            }
            printf("\n");
        }
    }
}
