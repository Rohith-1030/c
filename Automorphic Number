#include <stdio.h>
#include<stdlib.h>
int main() 
{
    int x,dig;
    scanf("%d",&x);
    int sq=x*x;
    int temp=x,div=1;
    while(temp>0)
    {
        div*=10;
        temp/=10;
    }
    if(sq%div==x)
    {
        printf("Automorphic Number");
    }
    else{
        printf("Not an Automorphic Number");
    }
}
