#include <stdio.h>

int main() 
{
    int n;
    scanf("%d",&n);
    int a[n];
    for(int i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    int count=1,sum;
    for(int i=0;i<n;i++)
    {
       
        for(int j=i;j<n;j++)
        {
            sum=0;
            printf("The Subrray of  %d :",count++);
            for(int k=i;k<=j;k++)
            {
                sum+=a[k];
            }
            printf("%d",sum);
            printf("\n");
        }
    }
}
    
	


