#include <stdio.h>

int main() 
{
    int n;
    scanf("%d",&n);
    int a[n][n];
    for(int i=0;i<n;i++)
    {
        for(int j=0;j<n;j++)
        {
            scanf("%d",&a[i][j]);
        }
    }
    int sum=0;
    for(int i=0;i<n;i++)
    {
        for(int j=0;j<n;j++)
        {
            for(int k=i;k<n;k++)
            {
                for(int l=j;l<n;l++)
                {
                    for(int x=i;x<=k;x++)
                    {
                        for(int y=j;y<=l;y++)
                        {
                            sum+=a[x][y];
                        }
                    }
                }
            }
        }
    }
    printf("%d",sum);
    return 0;
}



