#include <stdio.h>
#include<math.h>
int main() 
{
    int n,m;
    scanf("%d%d",&n,&m);;
    int c,sum,temp;
    for(int i=n;i<=m;i++)
    {
        sum=0;
        temp=i;
        c=0;
        while(temp>0)
        {
            c++;
            temp/=10;
        }
        temp=i;
        while(temp>0)
        {
            sum+=pow((temp%10),c);
            temp/=10;
        }
        if(i==sum)
        {
            printf("%d ",i);
        }
    }
}
