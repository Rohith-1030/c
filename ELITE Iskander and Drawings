#include <stdio.h>
#include<string.h>
void solve(){
    int n;
    char str[11];
    scanf("%d\n%s",&n,str);
    int max=0,curr=0;
    for(int i=0;str[i];i++)
    {
        if(str[i]=='#'){
            curr++;
            if(curr>max) max=curr;
        }else{curr=0;}
    }
    printf("%d\n",(max+1)/2);
}
int main() 
{
    int t;
    scanf("%d",&t);
    while(t--){
        solve();
    }
}
	


