int firstMissingPositive(int* nums, int numsSize) {
    int present[10000];
    for(int i=0;i<10000;i++)
    {
        present[i]=0;   
    }
    for(int i=0;i<numsSize;i++){
        if(nums[i]>100001 ||nums[i]<=0) continue;
        else present[nums[i]]=1;
    }
    for(int i=1;i<=100000;i++){
        if(present[i]==0) return i;
    }
    return 0;
}
