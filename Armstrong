#include <stdio.h>
#include<math.h>
int main() 
{
    int n;
    scanf("%d",&n);
    int c=0,sum=0,temp=n;
    while(temp>0)
    {
        c++;
        temp/=10;
    }
    temp=n;
    while(temp>0)
    {
        sum+=pow((temp%10),c);
        temp/=10;
    }
    if(n==sum)
    {
        printf("Armstrong ");
    }
    else{
        printf("Not a Armstrong");
    }
    
}
