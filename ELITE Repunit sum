#include <bits/stdc++.h>
using namespace std;

#define ll long long

void solve() {
    int n;
    cin >> n;

    vector<int> arr(n), ans;

    for (int i = 0; i < n; i++)
        cin >> arr[i];

    sort(arr.begin(), arr.end());

    ll carry = 0;

    for (int ctr = 1; ctr <= arr[n - 1]; ctr++) {
        auto it = lower_bound(arr.begin(), arr.end(), ctr);

        ll count = arr.end() - it;

        carry += count;

        ans.push_back(carry % 10);

        carry /= 10;
    }

    while (carry) {
        ans.push_back(carry % 10);
        carry /= 10;
    }

    reverse(ans.begin(), ans.end());

    for (int x : ans)
        cout << x;

    cout << '\n';
}

int main() {
    solve();
    return 0;
}
