#include <stdio.h>
#include<math.h>
int main() 
{
    int n;
    scanf("%d",&n);
    int a=0,b=1,next;
    if(n==0)
    {
        printf("%d",a);
    }
    else if(n==1)
    {
        printf("%d",b);
    }
    else{
        for(int i=2;i<=n;i++)
        {

            next=a+b;
            a=b;
            b=next;
        }
        printf("%d",b);
    }
    return 0;
}
