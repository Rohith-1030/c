#include <stdio.h>
#include<math.h>
int main() 
{
    int n,rev=0;
    scanf("%d",&n);
    while(n>0)
    {
        int dig=n%10;
        if(dig%2!=0)
        {
            rev=rev*10+dig;
            
        }
        n/=10;
    }
    int ans=0;
    while(rev>0)
    {
        ans=ans*10+rev%10;
        rev/=10;
    }
    printf("%d",ans);
}


