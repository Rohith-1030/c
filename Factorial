#include <stdio.h>

int main() 
{
    int n;
    scanf("%d",&n);
    int fact=1;
    if(n==0||n==1)
    {
        printf("1");
    }
    else if(n<0)
    {
        printf("Not Exist");
    }
    else{
        for(int i=1;i<=n;i++)
        {
            fact=fact*i;
        }
    }
    printf("The Factorial Of %d is: %d",n,fact);
}
    
	


