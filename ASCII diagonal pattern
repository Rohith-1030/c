#include <stdio.h>
#include<string.h>
int main()
{
   char str[100];
   scanf("%s",str);
   int n=strlen(str);
   for(int i=0;i<n;i++)
   {
       for(int j=0;j<n;j++)
       {
           int temp=str[j];
           
           if(i==j)
           {
               printf(" %d ",str[j]);
           }
           else {
               while(temp>0)
               {
                   printf("*");
                   temp/=10;
               }
               printf(" ");
           }
       }
       printf("\n");
   }
}


