#include <stdio.h>

int main() 
{
    int n;
    scanf("%d",&n);
    int a[n];
    for(int i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    int count=1;
    for(int i=0;i<n;i++)
    {
        for(int j=i;j<n;j++)
        {
            printf("The Subrray of  %d :",count++);
            for(int k=i;k<=j;k++)
            {
                printf("%d ",a[k]);
            }
            printf("\n");
        }
    }
}
    
	

