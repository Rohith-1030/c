#include <stdio.h>

int main() 
{
    int n;
    scanf("%d",&n);
    int dig,rev=0;
    int temp=n;
    while(temp>0)
    {
        dig=temp%10;
        rev=rev*10+dig;
        temp/=10;
    }
    if(n==rev)
    {
        printf("Palindrome");
    }
    else{
        printf("Not A Palindrome");
    }
    
}

