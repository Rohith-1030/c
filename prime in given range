#include <stdio.h>

int main() 
{
    int n,f;
    scanf("%d",&n);
    for(int i=2;i<=n;i++)
    {
        f=0;
        for(int j=2;j*j<=i;j++)
        {
            if(i%j==0)
            {
                f=1;
                break;
            }
            
        }
        if(!f)
        {
            printf("%d ",i);
        }
    }
    return 0;
}
 
