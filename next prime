#include <stdio.h>

int main() 
{
    int n;
    scanf("%d",&n);
    int f=0;
    for(int i=n+1; ;i++)
    {
        f=0;
        for(int j=2;j*j<=i;j++)
        {
            if(i%j==0)
            {
                f=1;
                break;
            }
        }
        if(f==0)
        {
            printf("%d",i);
            break;
        }
        
    }
    
}

	
