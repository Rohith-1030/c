#include<stdio.h>
#include <stdlib.h>
int main(){
    int n;
    scanf("%d",&n);
    int a[n];
    for(int i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    int prev=a[0];
    if(n>1&&a[1]%2!=0)
    {
        a[0]++;
    }
    for(int i=1;i<n-1;i++)
    {
        if(prev%2!=0&&a[i]%2!=0)        
        {
            prev=a[i];
            a[i]++;
        }
        else{
            prev=a[i];
        }
    }
    if(n>1&&prev%2!=0)
    {
        a[n-1]++;
    }
    for(int i=0;i<n;i++)
    {
        printf("%d ",a[i]);
    }
}
	
