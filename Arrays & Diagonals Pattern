#include <stdio.h>
int main()
{
    int n;
    scanf("%d",&n);
    int a[n];
    for(int i=0;i<n;i++){
        scanf("%d",&a[i]);
    }
    for(int i=0;i<n;i++)
    {
        for(int j=0;j<n;j++){
            if(i==j || i+j==n-1)
            {
                printf("%d ",a[j]);
            }
            else{
                int temp=a[j];
                if(temp==0)
                {
                    printf("* ");
                }
                else{
                    while(temp>0)
                    {
                        printf("*");
                        temp/=10;
                    }
                }
            }
        }
        printf("\n");
    }
}
            
            
    
