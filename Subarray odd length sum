#include <stdio.h>

int main()
{
    int n;
    scanf("%d",&n);
    int a[n];
    for(int i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    int total=0;
    for(int i=0;i<n;i++)
    {
        for(int j=i;j<n;j++)
        {
            int len=j-i+1;
            if(len%2!=0)
            {
                int sum=0;
                for(int k=i;k<=j;k++)
                {
                    sum+=a[k];
                }
                total+=sum;

            }
        }
    }
    printf("%d",total);
    
}
