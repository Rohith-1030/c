#include <stdio.h>

int main()
{
   int n;
   scanf("%d",&n);
   for(int i=n+1;;i++)
   {
       int t=i,last=0,rev=0;
       while(t>0)
       {
           last=t%10;
           rev=rev*10+last;
           t/=10;
           
       }
       if(rev==i)
       {
           printf("%d",i);
           break;
       }
   }
}

