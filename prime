#include <stdio.h>

int main() 
{
    int n;
    scanf("%d",&n);
    if(n<2)
    {
        printf("Not a Prime");
        return 0;
    }
    int f=0;
    for(int i=2;i<n/2;i++)
    {
        if(n%i==0)
        {
            f=1;
            break;
        }
    }
    if(f==0)
    
    {
        printf("Prime");
    }
    else{
        printf("Not a Prime");
    }
}
    

	
