#include <stdio.h>

int main() 
{
    int n,sum,count=0;
    scanf("%d",&n);
    int a[n];
    for(int i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    int k;
    scanf("%d",&k);
    for(int i=0;i<n;i++)
    {
        for(int j=i;j<n;j++)
        {
            sum=0;
            for(int k=i;k<=j;k++)
            {
                sum+=a[k];
            }
            if(sum==k)
            {
                count++;
            }
        }
    }
    printf("%d",count);
    
}
