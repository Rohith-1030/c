#include <stdio.h>

int main()
{
    int n;
    scanf("%d",&n);
    int a[n][n];
    for(int i=0;i<n;i++)
    {
        for(int j=0;j<n;j++)
        {
            scanf("%d",&a[i][j]);
        }
    }
    for(int i=0;i<n;i++)
    {
        for(int j=i;j<n;j++)
        {
            for(int k=0;k<n;k++)
            {
                for(int l=k;l<n;l++)
                {
                    for(int x=i;x<=j;x++)
                    {
                        for(int y=k;y<=l;y++)
                        {
                            printf("%d ",a[x][y]);
                        }
                        printf("\n");
                    }
                    printf("\n");
                }
            }
        }
    }
    
}
