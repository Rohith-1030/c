#include <stdio.h>

int main() 
{
    int n,max=0,end=-1;
    scanf("%d",&n);
    int a[n];
    for(int i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    int m;
    scanf("%d",&m);
    int b[m];
    for(int i=0;i<m;i++)
    {
        scanf("%d",&b[i]);
    }
    int dp[n+1][m+1];
    for(int i=0;i<=n;i++)
    {
        dp[i][0]=0;
    }
    for(int j=0;j<=m;j++)
    {
        dp[0][j]=0;
    }
    for(int i=1;i<=n;i++)
    {
        for(int j=1;j<=m;j++)
        {
            if(a[i-1]==b[j-1] )
            {
                
                dp[i][j]=dp[i-1][j-1]+1;
                if(dp[i][j]>max)
                {
                    max=dp[i][j];
                    end=i-1;
                }
                
            }
            else{
                dp[i][j]=0;
            }
        }
    }
    for(int i=end-max+1;i<=end;i++)
    {
        printf("%d ",a[i]);
    }
    printf("\n%d",max);
}
